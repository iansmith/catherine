package gen

import (
	"github.com/dop251/goja"
	rt "github.com/iansmith/webidl/jsbinding"
)

type ElementBinding struct {
	ctx    *rt.Ctx
	impl   Element
	parent *NodeBinding
}

func (b *ElementBinding) Get(key string) goja.Value {
	switch key {
	case "id":
		return b.ctx.VM().ToValue(b.ctx.ReflectGetString(b.impl, "id"))
	case "hidden":
		return b.ctx.VM().ToValue(b.ctx.ReflectGetBool(b.impl, "hidden"))
	case "className":
		return b.ctx.VM().ToValue(b.ctx.ReflectGetString(b.impl, "class"))
	case "tabIndex":
		return b.ctx.VM().ToValue(b.ctx.ReflectGetUint32(b.impl, "tabindex"))
	case "firstChild":
		return b.ctx.SameObject(b.impl, "firstChild", func() goja.Value { return b.ctx.WrapAny(b.impl.FirstChildAttr()) })
	case "append":
		return b.ctx.VM().ToValue(func(call goja.FunctionCall) goja.Value {
			switch len(call.Arguments) {
			case 1:
				switch b.ctx.ArgKind(call.Argument(0)) {
				case rt.KindObject:
					b.impl.Append1Node(b.ctx.Unwrap(call.Argument(0)))
					return goja.Undefined()
				case rt.KindString:
					b.impl.Append1String(rt.Coerce[string](b.ctx, call.Argument(0)))
					return goja.Undefined()
				default:
					b.impl.Append1String(rt.Coerce[string](b.ctx, call.Argument(0)))
					return goja.Undefined()
				}
			}
			return goja.Undefined()
		})
	case "resize":
		return b.ctx.VM().ToValue(func(call goja.FunctionCall) goja.Value {
			switch len(call.Arguments) {
			case 2:
				b.impl.Resize2(rt.Coerce[uint32](b.ctx, call.Argument(0)), rt.Coerce[uint32](b.ctx, call.Argument(1)))
				return goja.Undefined()
			case 3:
				b.impl.Resize3(rt.Coerce[uint32](b.ctx, call.Argument(0)), rt.Coerce[uint32](b.ctx, call.Argument(1)), rt.Coerce[uint32](b.ctx, call.Argument(2)))
				return goja.Undefined()
			}
			return goja.Undefined()
		})
	}
	return b.parent.Get(key)
}

func (b *ElementBinding) Set(key string, val goja.Value) bool {
	switch key {
	case "id":
		b.ctx.ReflectSetString(b.impl, "id", rt.Coerce[string](b.ctx, val))
		return true
	case "hidden":
		b.ctx.ReflectSetBool(b.impl, "hidden", rt.Coerce[bool](b.ctx, val))
		return true
	case "className":
		b.ctx.ReflectSetString(b.impl, "class", rt.Coerce[string](b.ctx, val))
		return true
	case "tabIndex":
		b.ctx.ReflectSetUint32(b.impl, "tabindex", rt.Coerce[uint32](b.ctx, val))
		return true
	}
	return b.parent.Set(key, val)
}

func (b *ElementBinding) Has(key string) bool {
	return key == "id" ||
		key == "hidden" ||
		key == "className" ||
		key == "tabIndex" ||
		key == "firstChild" ||
		key == "append" ||
		key == "resize" ||
		b.parent.Has(key)
}

func (b *ElementBinding) Delete(key string) bool {
	return b.parent.Delete(key)
}

func (b *ElementBinding) Keys() []string {
	return append([]string{"id", "hidden", "className", "tabIndex", "firstChild", "append", "resize"}, b.parent.Keys()...)
}

type NodeBinding struct {
	ctx  *rt.Ctx
	impl Node
}

func (b *NodeBinding) Get(key string) goja.Value {
	return goja.Undefined()
}

func (b *NodeBinding) Set(key string, val goja.Value) bool {
	return false
}

func (b *NodeBinding) Has(key string) bool {
	return false
}

func (b *NodeBinding) Delete(key string) bool {
	return false
}

func (b *NodeBinding) Keys() []string {
	return []string{}
}

func Register(vm *goja.Runtime, env rt.Env) *rt.Ctx {
	ctx := rt.NewCtx(vm, env)
	vm.Set("Element", func(call goja.ConstructorCall) *goja.Object {
		rt.ThrowType(vm, "Illegal constructor")
		return nil
	})
	vm.Set("Node", func(call goja.ConstructorCall) *goja.Object {
		rt.ThrowType(vm, "Illegal constructor")
		return nil
	})
	return ctx
}

var ExposedBindings = []rt.ExposedBinding{
	{Name: "Element", Globals: []string{"Window"}, New: func(ctx *rt.Ctx, impl any) goja.Value {
		return ctx.VM().NewDynamicObject(&ElementBinding{ctx: ctx, impl: impl.(Element)})
	}},
	{Name: "Node", Globals: []string{"*"}, New: func(ctx *rt.Ctx, impl any) goja.Value {
		return ctx.VM().NewDynamicObject(&NodeBinding{ctx: ctx, impl: impl.(Node)})
	}},
}
